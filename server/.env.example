# OpenAI-compatible chat model endpoint.
# Fill these from your local .env. For example, this can point to DeepSeek,
# OpenAI, Ollama, or any compatible gateway.
LLM_API_KEY=your_chat_api_key
LLM_BASE_URL=https://your-chat-provider.example/v1
LLM_MODEL=your_chat_model

# OpenAI-compatible embedding endpoint.
# Example for local Ollama: http://127.0.0.1:11434/v1 + bge-m3
LLM_EMBEDDING_API_KEY=ollama
LLM_EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
LLM_EMBEDDING_MODEL=bge-m3

# Print visible LLM requests, prompts, context payloads, raw responses, parsed JSON,
# and embedding metadata. Keep false unless you are debugging.
LLM_DEBUG_TRACE=false

# Optional fallback for tests or dev-only runs without Ollama
LLM_EMBEDDING_FALLBACK_MODE=
